{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "America/Argentina/Cordoba",
  // i) Semanal: PRs antes de las 08:00 AR todos los lunes
  "schedule": ["before 8am on Monday"],
  // Limitar ruido
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  // Mantener lockfiles frescos
  "lockFileMaintenance": { "enabled": true, "schedule": ["before 8am on Monday"] },
  // Managers que usamos
  "enabledManagers": ["npm", "github-actions"],
  // Commits semánticos
  "semanticCommits": "enabled",
  // Estrategia de versiones
  "rangeStrategy": "bump",
  // Reglas por paquete/tipo
  "packageRules": [
    {
      "description": "Automerge de devDependencies patch/minor",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Agrupar React/Next y no abrir mayor automáticamente",
      "matchPackageNames": ["react", "react-dom", "next"],
      "separateMajorMinor": true,
      "matchUpdateTypes": ["major"],
      "enabled": false,             // Los mayores los vemos trimestralmente a mano
      "labels": ["major-hold"]
    },
    {
      "description": "Firebase Admin y Express: revisar con más cuidado",
      "matchPackageNames": ["firebase-admin", "express"],
      "stabilityDays": 3,           // esperar 3 días desde release
      "labels": ["needs-manual-check"]
    }
  ],
  // Etiquetas y reviewers por defecto
  "labels": ["dependencies"],
  "reviewers": ["tu-usuario-github"]
}
